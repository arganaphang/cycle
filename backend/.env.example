# Comma-separated browser origins allowed to call /query with credentials (overrides built-in defaults).
# Include every frontend URL you use, e.g. http://localhost:5173,https://your-frontend.workers.dev
# CORS_ORIGINS="http://localhost:5173,https://physiorehab-frontend.argana.workers.dev"

DATABASE_USER="postgres"
DATABASE_PASS="postgres"
# Local dev: localhost. The `backend` service in docker-compose.yaml overrides this with `postgres`.
DATABASE_HOST="localhost"
DATABASE_NAME="cycle"
DATABASE_URL="postgres://${DATABASE_USER}:${DATABASE_PASS}@${DATABASE_HOST}:5432/${DATABASE_NAME}?sslmode=disable"
SECRET_KEY=""

# Set to 1 when the frontend is on a different site than the API (e.g. Workers app calling
# https://api.example.com). Requires HTTPS on the API. Omit for local dev with Vite proxy
# (same-origin /query) or when frontend and API share a schemeful same-site.
# AUTH_COOKIE_CROSS_SITE=1