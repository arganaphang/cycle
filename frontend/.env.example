# Production / direct API: must match CORS on the server (CORS_ORIGINS) when using cookies.
# VITE_BACKEND_URL=https://physiorehab.gbaajakarta.com
#
# Local dev (avoids CORS): set to your Vite dev origin so /query is same-origin; Vite proxies to the API.
# Must match the URL you open in the browser (port and host, e.g. localhost vs 127.0.0.1).
# VITE_BACKEND_URL=http://localhost:5173
#
# Optional: where to forward /query in dev (default: https://physiorehab.gbaajakarta.com)
# VITE_API_PROXY_TARGET=https://physiorehab.gbaajakarta.com